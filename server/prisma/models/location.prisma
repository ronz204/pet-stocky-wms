/// Specific location within the warehouse (Bin)
model Location {
  id       Int     @id @default(autoincrement())
  code     String // Ex: PAS-01-NIV-02-POS-04
  isActive Boolean @default(true)

  maxWeight Decimal? @db.Decimal(10, 2) // kg
  maxVolume Decimal? @db.Decimal(10, 2) // m3

  stocks Stock[]

  movementsAsSource Movement[] @relation("MovementSource")
  movementsAsDest   Movement[] @relation("MovementDest")

  warehouseId Int // Foreign key to Warehouse
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("locations")
  @@schema("stocky")
}
