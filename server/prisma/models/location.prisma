/// Specific location within the warehouse (Bin)
model Location {
  id       Int     @id @default(autoincrement())
  code     String // Ex: PAS-01-NIV-02-POS-04
  isActive Boolean @default(true)

  maxWeight Decimal? // kg
  maxVolume Decimal? // m3

  stocks Stock[]

  movementsAsSource Movement[] @relation("MovementSource")
  movementsAsDest   Movement[] @relation("MovementDest")

  werehouseId Int // Foreign key to Werehouse
  werehouse   Werehouse @relation(fields: [werehouseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("locations")
  @@schema("stocky")
}
