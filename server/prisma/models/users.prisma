model User {
  id       Int    @id @default(autoincrement())
  name     String @unique
  email    String @unique
  password String

  tenantId Int
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
  @@schema("stocky")
}
