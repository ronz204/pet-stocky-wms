model County {
  id   Int    @id @default(autoincrement())
  name String @unique

  districts District[]

  provinceId Int // Foreign key to Province
  province   Province @relation(fields: [provinceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("counties")
  @@schema("stocky")
}
