/// Inventory Movement. Immutable.
model Movement {
  id       Int     @id @default(autoincrement())
  quantity Decimal @default(0) @db.Decimal(10, 2)

  type MovementType

  productId Int // Foreign key to Product
  product   Product @relation(fields: [productId], references: [id])

  stockId Int? // Optional foreign key to StockLot
  stock   Stock? @relation(fields: [stockId], references: [id])

  fromLocationId Int? // For OUTBOUND and TRANSFER
  fromLocation   Location? @relation("MovementSource", fields: [fromLocationId], references: [id])

  toLocationId Int? // For INBOUND and TRANSFER
  toLocation   Location? @relation("MovementDest", fields: [toLocationId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("movements")
  @@schema("stocky")
}

enum MovementType {
  INBOUND // Inbound (Purchase, Production, Return)
  OUTBOUND // Outflow (Sales, Consumption, Shrinkage)
  TRANSFER // Internal movement (Location A -> B)

  @@schema("stocky")
}
