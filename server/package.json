{
  "name": "stocky",
  "version": "1.0.50",
  "scripts": {
    "dev": "bun run --watch source/boot.ts",
    "prisma:studio": "bunx --bun prisma studio",
    "prisma:generate": "bunx --bun prisma generate",
    "prisma:migrate": "bunx --bun prisma migrate dev",
    "build": "bun build source/boot.ts --compile --outfile=stocky"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/graphql-yoga": "^1.4.0",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.5.0",
    "elysia": "^1.4.22",
    "pg": "^8.17.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/pg": "^8.16.0",
    "prisma": "^7.5.0"
  },
  "private": true,
  "type": "module",
  "module": "src/boot.ts"
}
